MYSQL_ROOT_PASSWORD=replace-with-a-secure-root-password
MYSQL_DATABASE=Noorlocator
MYSQL_APP_USER=noorlocator
MYSQL_APP_PASSWORD=replace-with-a-secure-app-password
MYSQL_SERVER_VERSION=8.0.36

JWT_ISSUER=NoorLocator
JWT_AUDIENCE=NoorLocator.Client
JWT_KEY=replace-with-a-secure-random-32-character-minimum-secret

FRONTEND_RELATIVE_ROOT_PATH=frontend
FRONTEND_API_BASE_URL=
FRONTEND_PUBLIC_ORIGIN=https://your-frontend-host.example
MEDIA_STORAGE_RELATIVE_ROOT_PATH=uploads
MEDIA_STORAGE_PUBLIC_BASE_PATH=/uploads
MEDIA_STORAGE_PROVIDER=AzureBlob
AZURE_BLOB_STORAGE_CONNECTION_STRING=
AZURE_BLOB_STORAGE_SERVICE_URI=https://yourstorageaccount.blob.core.windows.net
AZURE_BLOB_STORAGE_ACCOUNT_NAME=
AZURE_BLOB_STORAGE_CONTAINER_NAME=uploads
AZURE_BLOB_STORAGE_PUBLIC_BASE_URL=
AZURE_BLOB_STORAGE_CREATE_CONTAINER_IF_MISSING=false
AZURE_BLOB_STORAGE_MANAGED_IDENTITY_CLIENT_ID=

SWAGGER_ENABLED=false
REVERSE_PROXY_USE_FORWARDED_HEADERS=false
HTTPS_REDIRECTION_ENABLED=false
SEEDING_APPLY_MIGRATIONS=true
SEEDING_SEED_REFERENCE_DATA=false
SEEDING_SEED_DEMO_DATA=false

CORS_ALLOWED_ORIGIN_0=https://your-frontend-host.example
CORS_ALLOWED_ORIGIN_1=
