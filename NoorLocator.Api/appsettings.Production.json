    "ManagedIdentityClientId": ""
  },
  "Seeding": {
    "ApplyMigrations": true,
    "SeedReferenceData": false,
    "SeedDemoData": false
  },
  "ReverseProxy": {
    "UseForwardedHeaders": true
  },
  "Https": {
    "RedirectionEnabled": false
  },
  "Swagger": {
    "Enabled": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
