{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "MySql": {
    "ServerVersion": "8.0.36"
  },
  "Jwt": {
    "Issuer": "NoorLocator",
    "Audience": "NoorLocator.Client",
    "Key": ""
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Frontend": {
    "RelativeRootPath": "frontend",
    "ApiBaseUrl": "",
    "PublicOrigin": ""
  },
  "AuthFlow": {
    "EmailVerificationTokenLifetimeMinutes": 1440,
    "PasswordResetTokenLifetimeMinutes": 60,
    "VerifyEmailPath": "verify-email.html",
    "ResetPasswordPath": "reset-password.html"
  },
  "SmtpSettings": {
    "Host": "",
    "Port": 587,
    "Username": "",
    "Password": "",
    "FromEmail": "noorlocator@gmail.com",
    "FromName": "NoorLocator",
    "UseSsl": true,
    "WriteToPickupDirectoryWhenDisabled": false,
    "PickupDirectory": ".codex-temp/email-outbox"
  },
  "MediaStorage": {
    "Provider": "AzureBlob",
    "PublicBasePath": "/uploads",
    "RelativeRootPath": "uploads",
    "MaxImageSizeBytes": 5242880
  },
  "AzureBlobStorage": {
    "ConnectionString": "",
    "ServiceUri": "",
    "AccountName": "",
    "ContainerName": "uploads",
    "PublicBaseUrl": "",
    "CreateContainerIfMissing": false,
    "UseBlobPublicAccess": true,
    "ManagedIdentityClientId": ""
  },
  "Seeding": {
    "ApplyMigrations": false,
    "SeedReferenceData": false,
    "SeedAdminAccount": false,
    "AdminName": "NoorLocator Admin",
    "AdminEmail": "admin@noorlocator.local",
    "AdminPassword": "",
    "SeedDemoData": false
  },
  "ReverseProxy": {
    "UseForwardedHeaders": true
  },
  "Https": {
    "RedirectionEnabled": true
  },
  "Swagger": {
    "Enabled": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
