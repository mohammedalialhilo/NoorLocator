{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "MySql": {
    "ServerVersion": "8.0.36"
  },
  "Jwt": {
    "Issuer": "NoorLocator",
    "Audience": "NoorLocator.Client",
    "Key": ""
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Frontend": {
    "RelativeRootPath": "frontend",
    "ApiBaseUrl": "",
    "PublicOrigin": ""
  },
  "MediaStorage": {
    "Provider": "AzureBlob",
    "PublicBasePath": "/uploads",
    "RelativeRootPath": "uploads",
    "MaxImageSizeBytes": 5242880
